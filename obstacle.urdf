<?xml version="1.0"?>
<robot name="obstacle">

  <!-- make the whole obstacle model static -->
  <gazebo>
    <static>true</static>
  </gazebo>

  <!-- world link used to attach all fixed obstacles -->
  <link name="world"/>

  <!-- ========================================================= -->
  <!-- red pillar -->
  <!-- ========================================================= -->
  <link name="pillar_red">

    <!-- visual shape -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.15"/>
      </geometry>
      <material name="Red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>

    <!-- collision shape -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.15"/>
      </geometry>
    </collision>

    <!-- inertial values -->
    <inertial>
      <mass value="3"/>
      <inertia ixx="0.1769" ixy="0" ixz="0"
               iyy="0.1769" iyz="0"
               izz="0.0338"/>
    </inertial>
  </link>

  <joint name="world_to_red" type="fixed">
    <parent link="world"/>
    <child link="pillar_red"/>
    <origin xyz="3.0 0.0 0.5" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- green pillar -->
  <!-- ========================================================= -->
  <link name="pillar_green">

    <!-- visual shape -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.15"/>
      </geometry>
      <material name="Green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>

    <!-- collision shape -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.15"/>
      </geometry>
    </collision>

    <!-- inertial values -->
    <inertial>
      <mass value="3"/>
      <inertia ixx="0.1769" ixy="0" ixz="0"
               iyy="0.1769" iyz="0"
               izz="0.0338"/>
    </inertial>
  </link>

  <joint name="world_to_green" type="fixed">
    <parent link="world"/>
    <child link="pillar_green"/>
    <origin xyz="4.2 2.5 0.5" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- blue pillar -->
  <!-- ========================================================= -->
  <link name="pillar_blue">

    <!-- visual shape -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.15"/>
      </geometry>
      <material name="Blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <!-- collision shape -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.15"/>
      </geometry>
    </collision>

    <!-- inertial values -->
    <inertial>
      <mass value="3"/>
      <inertia ixx="0.1769" ixy="0" ixz="0"
               iyy="0.1769" iyz="0"
               izz="0.0338"/>
    </inertial>
  </link>

  <joint name="world_to_blue" type="fixed">
    <parent link="world"/>
    <child link="pillar_blue"/>
    <origin xyz="4.2 -2.5 0.5" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- gazebo settings for blue pillar -->
  <!-- ========================================================= -->

<gazebo reference="pillar_red">
  <material>Gazebo/Red</material>
</gazebo>

<gazebo reference="pillar_green">
  <material>Gazebo/Green</material>
</gazebo>

<gazebo reference="pillar_blue">
  <material>Gazebo/Blue</material>
</gazebo>


</robot>